{
  "specialist": {
    "metadata": {
      "name": "node-coordinator",
      "version": "1.1.0",
      "description": "Coordinator hub for research nodes. READ_ONLY orchestrator that emits structured JSON decisions to route work across member specialists.",
      "category": "orchestration",
      "tags": [
        "node",
        "coordinator",
        "orchestration",
        "json",
        "keep-alive",
        "worktree"
      ],
      "created": "2026-04-03",
      "updated": "2026-04-09"
    },
    "execution": {
      "mode": "tool",
      "model": "openai-codex/gpt-5.4",
      "fallback_model": "anthropic/claude-sonnet-4-6",
      "timeout_ms": 0,
      "stall_timeout_ms": 180000,
      "interactive": true,
      "response_format": "json",
      "output_type": "orchestration",
      "permission_required": "READ_ONLY",
      "thinking_level": "low",
      "max_retries": 0
    },
    "prompt": {
      "system": "You are a node coordinator. You manage a fixed team of specialist members working toward a shared research goal. You are READ_ONLY \u2014 you do not write files or run code. You emit structured JSON decisions only.\n\nYour responsibilities:\n- Read member updates injected into your context\n- Decide which members to resume, steer, or stop next\n- Maintain a running memory patch as typed entries (fact/question/decision). REQUIRED fields: entry_type, summary, source_member_id (which member produced this finding), confidence (0-1)\n\nOutput contract requirements:\n- Return only one JSON object\n- Include only: summary, memory_patch, actions, validation\n- actions may only use: resume(memberId, task), steer(memberId, message), stop(memberId)\n- Do not emit any additional top-level fields\n\nNEVER emit prose outside of the JSON object. Your entire response must be a single valid JSON object matching the output schema.\n",
      "task_template": "$prompt\n\nNode context:\n$bead_context\n\nMember updates (if any):\n$pre_script_output\n",
      "output_schema": {
        "type": "object",
        "required": [
          "summary",
          "memory_patch",
          "actions",
          "validation"
        ],
        "properties": {
          "summary": {
            "type": "string"
          },
          "memory_patch": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "entry_type",
                "summary",
                "source_member_id",
                "confidence"
              ],
              "properties": {
                "entry_type": {
                  "type": "string",
                  "enum": [
                    "fact",
                    "question",
                    "decision"
                  ]
                },
                "entry_id": {
                  "type": "string"
                },
                "summary": {
                  "type": "string"
                },
                "source_member_id": {
                  "type": "string"
                },
                "confidence": {
                  "type": "number"
                },
                "provenance": {
                  "type": "object"
                }
              }
            }
          },
          "actions": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "required": [
                    "type",
                    "memberId",
                    "task"
                  ],
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": [
                        "resume"
                      ]
                    },
                    "memberId": {
                      "type": "string"
                    },
                    "task": {
                      "type": "string"
                    },
                    "dependsOnActionId": {
                      "type": "string"
                    }
                  }
                },
                {
                  "type": "object",
                  "required": [
                    "type",
                    "memberId",
                    "message"
                  ],
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": [
                        "steer"
                      ]
                    },
                    "memberId": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    },
                    "dependsOnActionId": {
                      "type": "string"
                    }
                  }
                },
                {
                  "type": "object",
                  "required": [
                    "type",
                    "memberId"
                  ],
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": [
                        "stop"
                      ]
                    },
                    "memberId": {
                      "type": "string"
                    },
                    "dependsOnActionId": {
                      "type": "string"
                    }
                  }
                }
              ]
            }
          },
          "validation": {
            "type": "object",
            "properties": {
              "ok": {
                "type": "boolean"
              },
              "issues": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "notes": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "skills": {
      "paths": [
        ".xtrm/skills/active/pi/using-specialists/"
      ],
      "scripts": [
        {
          "run": "specialists list",
          "phase": "pre",
          "inject_output": true
        }
      ]
    },
    "capabilities": {
      "required_tools": [
        "read",
        "grep",
        "find",
        "ls"
      ],
      "external_commands": [
        "bd",
        "git",
        "specialists"
      ]
    },
    "communication": {
      "next_specialists": []
    },
    "validation": {
      "files_to_watch": [
        "src/specialist/schema.ts",
        "src/specialist/runner.ts",
        "src/specialist/worktree.ts",
        "src/specialist/supervisor.ts"
      ],
      "stale_threshold_days": 30
    },
    "beads_integration": "auto",
    "stall_detection": {},
    "beads_write_notes": true
  }
}
